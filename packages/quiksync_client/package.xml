<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>quiksync_client</name>
  <version>0.2.2</version> <!-- x-release-please-version -->
  <description>HTTPS + WSS client for the QuikSync Open-RMF adapter API. Shared core used by the fleet, door, and lift adapter packages.</description>
  <maintainer email="tech@quikbot.ai">QuikBot</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <depend>python3-httpx</depend>
  <depend>python3-websockets</depend>
  <depend>python3-pydantic</depend>

  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
