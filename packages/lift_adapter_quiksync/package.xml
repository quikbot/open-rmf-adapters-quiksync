<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>lift_adapter_quiksync</name>
  <version>0.2.1</version> <!-- x-release-please-version -->
  <description>QuikSync Open-RMF lift adapter — bridges QuikSync-managed lifts to a customer Open-RMF deployment.</description>
  <maintainer email="tech@quikbot.ai">QuikBot</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <depend>quiksync_client</depend>
  <depend>rclpy</depend>
  <depend>rmf_lift_msgs</depend>

  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
